<idea-plugin url="https://github.com/queukat/configiq-airflow-kafka-connect">
    <id>com.configiq.airflowkconnect</id>
    <name>ConfigIQ Ops</name>
    <vendor url="https://github.com/queukat" email="75810528+queukat@users.noreply.github.com">ConfigIQ</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends optional="true" config-file="com.configiq.airflowkconnect-with-python.xml">com.intellij.modules.python</depends>
    <depends>com.intellij.modules.json</depends>
    <depends>com.intellij.properties</depends>
    <depends>org.intellij.intelliLang</depends>
    <depends>org.jetbrains.plugins.yaml</depends>

    <description><![CDATA[
        <p>ConfigIQ Ops is a narrow authoring assistant for Airflow DAG schedules and Kafka Connect configs.</p>
        <ul>
            <li>validates Airflow schedule strings and previews the next runs</li>
            <li>flags high-value Kafka Connect conflicts and missing required keys</li>
            <li>adds focused quick fixes and RegExp injection for JSON, YAML, and properties regex fields</li>
        </ul>
    ]]></description>

    <change-notes><![CDATA[
        <p>Kafka Connect properties regex support and release hardening.</p>
        <ul>
            <li>Added RegExp injection for Kafka Connect <code>.properties</code> regex fields.</li>
            <li>Covered <code>topics.regex</code> properties injection with a regression test.</li>
            <li>Added <code>ktlintCheck</code> and <code>detekt</code> to the documented release gate.</li>
        </ul>
    ]]></change-notes>

    <extensions defaultExtensionNs="com.intellij">
        <applicationConfigurable
                parentId="tools"
                instance="com.configiq.settings.ConfigIqSettingsConfigurable"
                id="com.configiq.airflowkconnect.settings"
                displayName="ConfigIQ"/>
        <multiHostInjector implementation="com.configiq.injection.KConnectRegexInjector"/>
        <localInspection
                language="JSON"
                shortName="KConnectJsonProblems"
                displayName="Kafka Connect config problem"
                groupPath="ConfigIQ"
                groupName="Kafka Connect"
                enabledByDefault="true"
                level="WARNING"
                implementationClass="com.configiq.inspection.KConnectJsonInspection"/>
        <localInspection
                language="yaml"
                shortName="KConnectYamlProblems"
                displayName="Kafka Connect config problem"
                groupPath="ConfigIQ"
                groupName="Kafka Connect"
                enabledByDefault="true"
                level="WARNING"
                implementationClass="com.configiq.inspection.KConnectYamlInspection"/>
        <localInspection
                language="Properties"
                shortName="KConnectPropertiesProblems"
                displayName="Kafka Connect config problem"
                groupPath="ConfigIQ"
                groupName="Kafka Connect"
                enabledByDefault="true"
                level="WARNING"
                implementationClass="com.configiq.inspection.KConnectPropertiesInspection"/>
    </extensions>
</idea-plugin>
